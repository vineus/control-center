# Control Center configuration
# Copy to ~/.control-center/config.toml
# Env vars with CC_ prefix override these values (e.g. CC_AUTOFIX_ENABLED=true)

[github]
# Your GitHub username (auto-detected from `gh` CLI on first run)
username = ""
# Default org to filter PRs (leave empty for all orgs)
default_org = ""

[server]
host = "0.0.0.0"
port = 8000
poll_interval_seconds = 180

[autofix]
enabled = false
max_budget_usd = 2.0
max_turns = 30
cooldown_minutes = 60
model = "sonnet"
repos_base_dir = "~/.control-center/repos"
